#include <stdio.h>
#include <string.h>
#include <ctype.h>

unsigned long long fact(int n) {
    unsigned long long f = 1;
    for (int i = 2; i <= n; i++)
        f *= i;
    return f;
}

int main() {
    char s[15];
    int cnt[256] = {0};

    scanf("%14s", s);

    int n = strlen(s);

    for (int i = 0; i < n; i++) {
        s[i] = tolower(s[i]);
        cnt[(unsigned char)s[i]]++;
    }

    unsigned long long ans = fact(n);

    for (int i = 0; i < 256; i++)
        if (cnt[i] > 1)
            ans /= fact(cnt[i]);

    printf("%llu", ans);

    return 0;
}