#include <stdio.h>

int main() {
    long long x, y, d;
    scanf("%lld %lld", &x, &y);

    d = y - x;

    long long n = 0;

    while (n * n < d)
        n++;

    if (d == 0)
        printf("0");
    else if (d == n * n)
        printf("%lld", 2 * n - 1);
    else if (d <= n * n - n)
        printf("%lld", 2 * n - 2);
    else
        printf("%lld", 2 * n - 1);

    return 0;
}