#include <stdio.h>

#define MOD 12345

int main() {
    int n;
    scanf("%d", &n);

    int a0 = 1, a1 = 1, a2 = 0;

    for (int i = 2; i <= n; i++) {
        int b0 = (a0 + a1 + a2) % MOD;
        int b1 = a0;
        int b2 = a1;

        a0 = b0;
        a1 = b1;
        a2 = b2;
    }

    printf("%d", (a0 + a1 + a2) % MOD);

    return 0;
}