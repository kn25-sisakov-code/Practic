#include <stdio.h>

int gcd(int a, int b) {
    while (b != 0) {
        int t = a % b;
        a = b;
        b = t;
    }
    return a;
}

int main() {
    int p, x, lcm;

    scanf("%d", &p);
    scanf("%d", &lcm);

    for (int i = 1; i < p; i++) {
        scanf("%d", &x);
        lcm = lcm / gcd(lcm, x) * x;
    }

    printf("%d", lcm);

    return 0;
}